# Default multilingual Whisper (Arabic + English). First run downloads ~500MB.
# WHISPER_MODEL=Xenova/whisper-small
# Faster / smaller (weaker Arabic): Xenova/whisper-tiny

# Optional — Growth Hub / AI Assistant LLM refine (heuristics always work without this).
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# Full dub TTS uses the same key (gpt-4o-mini-tts).

# Public app URL for OAuth redirects (defaults to request host).
# APP_BASE_URL=http://localhost:3000

# YouTube publish (Google Cloud OAuth client — YouTube Data API v3).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional future platform OAuth (connect UI lights up when set).
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# META_APP_ID=
# META_APP_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# X_CLIENT_ID=
# X_CLIENT_SECRET=
