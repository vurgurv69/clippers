# Default Whisper model — tiny is much faster on CPU (Arabic + English).
# For higher Arabic accuracy (slower): Xenova/whisper-small
# WHISPER_MODEL=Xenova/whisper-tiny
# Cap how many seconds of speech Whisper processes (rest uses audio scoring).
# WHISPER_MAX_SECONDS=600

# Optional — Growth Hub / viral clip refine + AI Assistant (heuristics always work without this).
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# Full dub TTS uses the same key (gpt-4o-mini-tts).

# Public app URL for OAuth redirects (defaults to request host).
# APP_BASE_URL=http://localhost:3000

# YouTube publish (Google Cloud OAuth client — YouTube Data API v3).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional future platform OAuth (connect UI lights up when set).
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# META_APP_ID=
# META_APP_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# X_CLIENT_ID=
# X_CLIENT_SECRET=
